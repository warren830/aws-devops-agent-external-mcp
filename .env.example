# AWS Global
AWS_GLOBAL_ACCESS_KEY_ID=
AWS_GLOBAL_SECRET_ACCESS_KEY=
AWS_GLOBAL_REGION=us-east-1

# AWS China (cn-north-1 / cn-northwest-1)
AWS_CN_ACCESS_KEY_ID=
AWS_CN_SECRET_ACCESS_KEY=
AWS_CN_REGION=cn-north-1

# Alibaba Cloud
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# domestic | international
ALIYUN_ENV=domestic

# Google Cloud (scope: Cloud Run only via @google-cloud/cloud-run-mcp)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
# Path to service-account JSON on your host (will be mounted into the container)
GCP_SA_KEY_FILE=./gcp-sa-key.json
