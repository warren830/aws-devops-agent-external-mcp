# Aliyun MCP server image. Separated from the AWS image because
# alibaba-cloud-ops-mcp-server pins fastmcp==2.8.0 which conflicts with
# awslabs.aws-api-mcp-server's fastmcp range.
#
# Base image uses AWS public ECR mirror of Docker Hub (国内网络更稳定, see
# BLOG.md pitfall #2).

FROM public.ecr.aws/docker/library/python:3.12-slim

ARG ALIYUN_MCP_VERSION=0.9.27

RUN pip install --no-cache-dir \
      "alibaba-cloud-ops-mcp-server==${ALIYUN_MCP_VERSION}"

RUN useradd --create-home --shell /bin/bash app
USER app
WORKDIR /home/app

EXPOSE 8000
